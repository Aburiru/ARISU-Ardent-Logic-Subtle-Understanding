<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta charset="UTF-8">
    <title>ARISU Interface</title>
    
    <HTA:APPLICATION 
        ID="ARISU_PRO"
        APPLICATIONNAME="ARISU"
        BORDER="thin"
        INNERBORDER="no"
        CAPTION="yes"
        MAXIMIZEBUTTON="yes"
        MINIMIZEBUTTON="yes"
        SHOWINTASKBAR="yes"
        SINGLEINSTANCE="yes"
        SYSMENU="yes"
        WINDOWSTATE="normal"
        SCROLL="no"
    />
    
    <style>
        :root {
            --bg: #0f111a;
            --panel: rgba(26, 29, 46, 0.7);
            --accent: #bb86fc;
            --accent-dim: #7c4dff;
            --text-p: #e1e1e6;
            --text-s: #949eb3;
            --user-grad: linear-gradient(135deg, #6200ee, #3700b3);
            --arisu-bg: rgba(187, 134, 252, 0.08);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Segoe UI', Tahoma, sans-serif;
            background-color: var(--bg);
            background-image: 
                radial-gradient(at 0% 0%, rgba(124, 77, 255, 0.1) 0px, transparent 50%),
                radial-gradient(at 100% 100%, rgba(3, 218, 198, 0.05) 0px, transparent 50%);
            color: var(--text-p);
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .app-bar {
            height: 70px;
            background: var(--panel);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding: 0 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 10;
            flex-shrink: 0;
        }

        .logo-area { display: flex; align-items: center; gap: 30px; }
        
        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #444;
            box-shadow: 0 0 5px rgba(255, 255, 255, 0.1);
            transition: all 0.5s ease;
        }
        
        .status-dot.online { background: #03dac6; box-shadow: 0 0 12px rgba(3, 218, 198, 0.6); }
        .status-dot.thinking { background: var(--accent); box-shadow: 0 0 15px rgba(187, 134, 252, 0.8); animation: pulse-dot 1.5s infinite; }

        @keyframes pulse-dot { 0% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.3); opacity: 0.6; } 100% { transform: scale(1); opacity: 1; } }

        .title { font-weight: 300; letter-spacing: 3px; font-size: 18px; color: var(--accent); }

        .nav-actions { display: flex; gap: 12px; }
        .icon-btn {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.1);
            color: var(--text-s);
            padding: 8px 15px;
            border-radius: 5px;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: 0.3s;
        }
        .icon-btn:hover { background: rgba(187, 134, 252, 0.1); color: var(--accent); border-color: var(--accent); }

        .viewport {
            flex: 1;
            overflow-y: auto;
            padding: 40px 15%;
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .viewport::-webkit-scrollbar { width: 4px; }
        .viewport::-webkit-scrollbar-thumb { background: rgba(187, 134, 252, 0.2); border-radius: 10px; }

        .msg-row { display: flex; flex-direction: column; max-width: 100%; animation: slideIn 0.4s cubic-bezier(0.1, 0.9, 0.2, 1); flex-shrink: 0; }
        @keyframes slideIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .msg-row.user { align-items: flex-end; }
        .msg-row.arisu { align-items: flex-start; }

        .msg-meta { font-size: 10px; color: var(--text-s); margin-bottom: 8px; text-transform: uppercase; letter-spacing: 1px; }
        
        .bubble {
            padding: 14px 20px;
            border-radius: 18px;
            font-size: 14.5px;
            line-height: 1.6;
            max-width: 80%;
            width: fit-content;
            display: inline-block;
            word-wrap: break-word;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .user .bubble {
            background: var(--user-grad);
            color: #000000;
            border-top-right-radius: 2px;
        }

        .arisu .bubble {
            background: var(--arisu-bg);
            border: 1px solid rgba(187, 134, 252, 0.15);
            backdrop-filter: blur(10px);
            border-top-left-radius: 2px;
        }

        .bottom-bar {
            padding: 30px 15%;
            background: linear-gradient(to top, var(--bg) 60%, transparent);
            flex-shrink: 0;
        }

        .input-box {
            background: var(--panel);
            border: 1px solid rgba(187, 134, 252, 0.2);
            border-radius: 15px;
            padding: 8px;
            display: flex;
            align-items: flex-end;
            box-shadow: 0 15px 50px rgba(0,0,0,0.3);
        }

        #messageInput {
            flex: 1;
            background: transparent;
            border: none;
            color: var(--text-p);
            padding: 12px 15px;
            font-size: 14px;
            outline: none;
            resize: none;
            max-height: 200px;
            font-family: inherit;
            overflow-y: hidden;
        }

        .send-action {
            width: 45px;
            height: 45px;
            background: var(--accent);
            border: none;
            border-radius: 12px;
            color: #000;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
            margin-left: 10px;
        }

        .typing-ghost {
            font-size: 12px;
            color: var(--accent);
            padding: 10px 15%;
            display: none;
            font-style: italic;
        }
    </style>
</head>
<body>

    <div class="app-bar">
        <div class="logo-area">
            <div id="statusDot" class="status-dot"></div>&nbsp;&nbsp;
            <div class="title">ARISU <span>CORE</span></div>
        </div>
        <div class="nav-actions">
            <button class="icon-btn" id="voiceToggleBtn" onclick="toggleVoiceMode()" data-mode="normal">Voice: Normal</button>
            <button class="icon-btn" onclick="showStats()">Analytics</button>
            <button class="icon-btn" onclick="clearChat()">Wipe Memory</button>
        </div>
    </div>

    <div class="viewport" id="chatViewport">
        <div id="loading" style="text-align:center; padding: 100px; color: var(--text-s);">
            Synchronising Neural Interface...
        </div>
    </div>

    <div class="typing-ghost" id="typingLabel">ARISU is thinking...</div>

    <div class="bottom-bar">
        <div class="input-box">
            <textarea id="messageInput" placeholder="Message ARISU..." rows="1"></textarea>
            <button id="sendBtn" class="send-action" onclick="sendMessage()"><b>&gt;</b></button>
        </div>
    </div>

    <script language="javascript">
        var API_URL = 'http://127.0.0.1:5001/api';
        var isBusy = false;

        window.onload = function() {
            window.resizeTo(1000, 800);
            autoSizeInput();
            pingAPI();
            loadSettings();
            setInterval(checkStatus, 5000);
        };

        window.onbeforeunload = function() {
            try {
                var xhr = new ActiveXObject("Microsoft.XMLHTTP");
                xhr.open("POST", API_URL + "/shutdown", false);
                xhr.send();
            } catch(e) {}
        };

        function toggleVoiceMode() {
            var btn = document.getElementById('voiceToggleBtn');
            var currentMode = btn.getAttribute('data-mode');
            var nextMode = currentMode === 'rvc' ? 'normal' : 'rvc';
            
            try {
                var xhr = new ActiveXObject("Microsoft.XMLHTTP");
                xhr.open("POST", API_URL + "/settings", true);
                xhr.setRequestHeader("Content-Type", "application/json");
                xhr.onreadystatechange = function() {
                    if (xhr.readyState === 4 && xhr.status === 200) {
                        var res = eval('(' + xhr.responseText + ')');
                        updateVoiceButton(res.voice_mode);
                    }
                };
                xhr.send('{"voice_mode":"' + nextMode + '"}');
            } catch(e) { alert("Failed to toggle voice mode"); }
        }

        function updateVoiceButton(mode) {
            var btn = document.getElementById('voiceToggleBtn');
            btn.setAttribute('data-mode', mode);
            btn.innerHTML = mode === 'rvc' ? 'Voice: RVC' : 'Voice: Normal';
            btn.style.borderColor = mode === 'rvc' ? 'var(--accent)' : 'rgba(255,255,255,0.1)';
            btn.style.color = mode === 'rvc' ? 'var(--accent)' : 'var(--text-s)';
        }

        function loadSettings() {
            try {
                var xhr = new ActiveXObject("Microsoft.XMLHTTP");
                xhr.open("GET", API_URL + "/settings", true);
                xhr.onreadystatechange = function() {
                    if (xhr.readyState === 4 && xhr.status === 200) {
                        var res = eval('(' + xhr.responseText + ')');
                        updateVoiceButton(res.voice_mode);
                        if (!res.rvc_available) {
                             var btn = document.getElementById('voiceToggleBtn');
                             btn.disabled = true;
                             btn.title = "RVC Model not found at rvc_models/arisu.pth";
                             btn.style.opacity = "0.5";
                        }
                    }
                };
                xhr.send();
            } catch(e) {}
        }

        function scrollToBottom() {
            var view = document.getElementById('chatViewport');
            view.scrollTop = view.scrollHeight;
            // Backup scroll for some HTA versions
            setTimeout(function() { view.scrollTop = view.scrollHeight; }, 50);
        }

        function setStatus(state) {
            var dot = document.getElementById('statusDot');
            if (state === 'online') { dot.className = 'status-dot online'; } 
            else if (state === 'thinking') { dot.className = 'status-dot thinking'; } 
            else { dot.className = 'status-dot'; }
        }

        function checkStatus() {
            if (isBusy) return;
            try {
                var xhr = new ActiveXObject("Microsoft.XMLHTTP");
                xhr.open("GET", API_URL + "/status", true);
                xhr.onreadystatechange = function() {
                    if (xhr.readyState === 4 && xhr.status === 200) setStatus('online');
                    else if (xhr.readyState === 4) setStatus('offline');
                };
                xhr.send();
            } catch(e) { setStatus('offline'); }
        }

        function autoSizeInput() {
            var el = document.getElementById('messageInput');
            el.oninput = function() {
                this.style.height = 'auto';
                this.style.height = (this.scrollHeight) + 'px';
            };
            el.onkeydown = function(e) {
                if(e.keyCode === 13 && !e.shiftKey) {
                    e.preventDefault();
                    sendMessage();
                }
            };
        }

        function pingAPI() {
            try {
                var xhr = new ActiveXObject("Microsoft.XMLHTTP");
                xhr.open("GET", API_URL + "/greeting", true);
                xhr.onreadystatechange = function() {
                    if (xhr.readyState === 4 && xhr.status === 200) {
                        document.getElementById('loading').style.display = 'none';
                        setStatus('online');
                        loadLogs();
                    }
                };
                xhr.send();
            } catch(e) { setStatus('offline'); }
        }

        function loadLogs() {
            try {
                var xhr = new ActiveXObject("Microsoft.XMLHTTP");
                xhr.open("GET", API_URL + "/history", true);
                xhr.onreadystatechange = function() {
                    if (xhr.readyState === 4 && xhr.status === 200) {
                        var data = eval('(' + xhr.responseText + ')');
                        if(data.messages) {
                            for(var i=0; i<data.messages.length; i++) {
                                var m = data.messages[i];
                                pushMessage(m.role === 'user' ? 'YOU' : 'ARISU', m.content, m.role === 'user' ? 'user' : 'arisu');
                            }
                            scrollToBottom();
                        }
                    }
                };
                xhr.send();
            } catch(e) {}
        }

        function sendMessage() {
            if(isBusy) return;
            var input = document.getElementById('messageInput');
            var val = input.value.replace(/^\s+|\s+$/g, '');
            if(!val) return;

            isBusy = true;
            input.disabled = true;
            document.getElementById('typingLabel').style.display = 'block';
            setStatus('thinking');

            pushMessage('YOU', val, 'user');
            input.value = '';
            input.style.height = 'auto';
            scrollToBottom();

            var xhr = new ActiveXObject("Microsoft.XMLHTTP");
            xhr.open("POST", API_URL + "/chat", true);
            xhr.setRequestHeader("Content-Type", "application/json");
            xhr.onreadystatechange = function() {
                if (xhr.readyState === 4) {
                    document.getElementById('typingLabel').style.display = 'none';
                    if (xhr.status === 200) {
                        var res = eval('(' + xhr.responseText + ')');
                        pushMessage('ARISU', res.response, 'arisu', res.timestamp, res.emotion);
                        setStatus('online');
                        scrollToBottom();
                    } else { setStatus('offline'); }
                    isBusy = false;
                    input.disabled = false;
                    input.focus();
                }
            };
            xhr.send('{"message":"' + jsonSafe(val) + '"}');
        }

        function pushMessage(sender, text, type, time, emo) {
            var view = document.getElementById('chatViewport');
            var row = document.createElement('div');
            row.className = 'msg-row ' + type;
            time = time || (new Date().getHours() + ':' + (new Date().getMinutes()<10?'0':'') + new Date().getMinutes());

            row.innerHTML = 
                '<div class="msg-meta">' + sender + ' &bull; ' + time + '</div>' +
                '<div class="bubble">' + parseMarkdown(text) + '</div>';
            
            view.appendChild(row);
        }

        function parseMarkdown(t) {
            t = t.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            t = t.replace(/\n/g, '<br>');
            return t;
        }

        function jsonSafe(s) {
            return s.replace(/\\/g, '\\\\').replace(/"/g, '\\"').replace(/\n/g, '\\n').replace(/\r/g, '');
        }

        function showStats() {
            try {
                var xhr = new ActiveXObject("Microsoft.XMLHTTP");
                xhr.open("GET", API_URL + "/stats", false);
                xhr.send();
                var d = eval('(' + xhr.responseText + ')');
                alert('Stats: ' + d.message_count + ' messages.');
            } catch(e) {}
        }

        function clearChat() {
            if(confirm('Purge short-term memory?')) {
                var xhr = new ActiveXObject("Microsoft.XMLHTTP");
                xhr.open("POST", API_URL + "/clear", false);
                xhr.send();
                window.location.reload();
            }
        }
    </script>
</body>
</html>
